{
  "name": "oxview",
  "productName": "oxview",
  "version": "1.0.2",
  "description": "OxDNA viewer and editor.",
  "main": "./index.js",
  "scripts": {
    "build:three": "node ./scripts/build-three-compat.mjs",
    "build:app": "tsc",
    "build": "npm run build:three && npm run build:app",
    "prepare:gh-pages": "node ./scripts/prepare-gh-pages.mjs",
    "start": "electron-forge start",
    "start:cdp": "electron-forge start -- --cdp",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\"",
    "load": "npm run build:three && tsc -w & reload -b",
    "save-canvas-image": "electron ./script/save-canvas-image.js",
    "langgraph:install": "npm --prefix ./langGraph install",
    "langgraph:build": "npm --prefix ./langGraph run build",
    "langgraph:test": "npm --prefix ./langGraph run test",
    "langgraph:chat": "npm --prefix ./langGraph run chat"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sulcgroup/oxdna-viewer.git"
  },
  "keywords": [],
  "author": {
    "name": "EJM",
    "email": "psulc@asu.edu"
  },
  "license": "GPL-3.0-or-later",
  "config": {
    "forge": {
      "packagerConfig": {},
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "my_app"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-deb",
          "config": {}
        },
        {
          "name": "@electron-forge/maker-rpm",
          "config": {}
        }
      ]
    }
  },
  "dependencies": {
    "@types/chart.js": "^2.9.31",
    "@types/chartjs-plugin-annotation": "^0.5.1",
    "@types/jquery": "^3.5.6",
    "@types/moment": "^2.13.0",
    "@types/node": "^22.7.4",
    "@types/sizzle": "2.3.2",
    "@types/webvr-api": "0.0.36",
    "@zip.js/zip.js": "^2.3.17",
    "electron-settings": "^4.0.2",
    "electron-squirrel-startup": "^1.0.0",
    "reload": "^3.4.2",
    "rpmbuild": "0.0.23",
    "three": "^0.183.2",
    "typescript": "^5.9.3",
    "update-electron-app": "^2.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^6.0.0-beta.59",
    "@electron-forge/maker-deb": "^6.0.0-beta.59",
    "@electron-forge/maker-rpm": "^6.0.0-beta.59",
    "@electron-forge/maker-squirrel": "^6.0.0-beta.59",
    "@electron-forge/maker-zip": "^6.0.0-beta.59",
    "@types/three": "^0.183.1",
    "electron": "22.0.0",
    "esbuild": "^0.27.4"
  }
}
